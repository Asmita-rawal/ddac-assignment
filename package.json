{
  "name": "safetrack",
  "version": "1.0.0",
  "description": "SafeTrack - Elderly Safety Tracking System",
  "main": "backend/server.js",
  "scripts": {
    "start": "node backend/server.js",
    "dev": "nodemon backend/server.js",
    "test-db": "node backend/test-db.js",
    "setup-db": "node scripts/setup-db.js",
    "test-storage": "node backend/test-storage.js",
    "test-api": "node test-api.js",
    "schema": "mysql -u root -p < database/schema.sql",
    "seed": "mysql -u root -p < database/seed.sql",
    "db:reset": "npm run schema && npm run seed"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^4.22.2",
    "express-validator": "^7.3.2",
    "jsonwebtoken": "^9.0.0",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.22.5"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
